@page "/ranking"
@using myapp.Services
@inject RankingService RankingService
@implements IDisposable

<div class="ranking-page">
    <div class="ranking-banner">
        <img src="@SkinConfig.Url("banners/banner_galaxy.jpg")" alt="Ranking" onerror="this.style.display='none'" />
        <div class="ranking-banner-title">Ranking</div>
    </div>

    <div class="ranking-container">
        <table class="ranking-table">
            <thead>
                <tr>
                    <th class="col-rank">#</th>
                    <th class="col-name">Jugador</th>
                    <th class="col-type">Tipo</th>
                    <th class="col-points">Puntos</th>
                    <th class="col-stars">Victorias</th>
                    <th class="col-defeats">Derrotas</th>
                </tr>
            </thead>
            <tbody>
                @{
                    var rankings = RankingService.GetRankings();
                    int rank = 1;
                }
                @foreach (var entry in rankings)
                {
                    <tr class="@(entry.PlayerKey == RankingService.PlayerKey ? "row-player" : "row-bot")">
                        <td class="col-rank">@rank</td>
                        <td class="col-name">
                            <span class="player-name">@entry.DisplayName</span>
                            @if (!string.IsNullOrEmpty(entry.PlayerKey) && entry.PlayerKey != RankingService.PlayerKey)
                            {
                                <span class="coords">[@entry.PlayerKey]</span>
                            }
                        </td>
                        <td class="col-type">
                            @if (entry.IsBot)
                            {
                                <span class="badge-bot">Bot</span>
                            }
                            else
                            {
                                <span class="badge-player">Jugador</span>
                            }
                        </td>
                        <td class="col-points">@entry.Points.ToString("N0")</td>
                        <td class="col-stars">
                            @for (int i = 0; i < entry.Stars; i++)
                            {
                                <span class="star filled">★</span>
                            }
                            @for (int i = entry.Stars; i < 3; i++)
                            {
                                <span class="star empty">☆</span>
                            }
                        </td>
                        <td class="col-defeats">
                            @for (int i = 0; i < entry.Defeats; i++)
                            {
                                <span class="defeat-mark">✕</span>
                            }
                            @for (int i = entry.Defeats; i < 3; i++)
                            {
                                <span class="defeat-empty">·</span>
                            }
                        </td>
                    </tr>
                    rank++;
                }
                @if (!rankings.Any())
                {
                    <tr>
                        <td colspan="6" class="empty-msg">No hay datos de ranking todavia. Empieza a construir y combatir para aparecer en la tabla.</td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="ranking-legend">
            <h3>Reglas de puntuacion</h3>
            <ul>
                <li>Cada 1.000 Metal gastado = <strong>1 pto</strong></li>
                <li>Cada 1.000 Crystal gastado = <strong>1.2 ptos</strong></li>
                <li>Cada 1.000 Deuterio gastado = <strong>1.5 ptos</strong></li>
                <li>Destruir naves enemigas = <strong>+10%</strong> del valor en puntos</li>
                <li>Destruir defensas enemigas = <strong>+5%</strong> del valor en puntos</li>
                <li>Naves/Defensas propias destruidas = <strong>-puntos</strong> equivalentes</li>
                <li><span class="star filled">★</span> = Victoria en batalla (max 3)</li>
                <li><span class="defeat-mark">✕</span> = Derrota en batalla (max 3)</li>
            </ul>
        </div>
    </div>
</div>

@code {
    protected override void OnInitialized()
    {
        RankingService.OnChange += OnRankingChanged;
    }

    private void OnRankingChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        RankingService.OnChange -= OnRankingChanged;
    }
}
