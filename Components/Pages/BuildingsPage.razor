@page "/buildings"
@using Microsoft.AspNetCore.Components
@using myapp.Services
@inject NavigationManager Navigation
@inject ResourceService ResourceService
@inject BuildingService BuildingService
@inject RequirementService RequirementService

@implements IDisposable

<PageTitle>Buildings</PageTitle>

<div class="espacial-container">
    <!-- Banner -->
    <div class="espacial-banner" style="background-image: url('@SkinConfig.Url("banners/buildings-banner.jpg")');">
        <h2>Buildings</h2>
        <p>Construct and upgrade planetary infrastructure</p>
    </div>

    <!-- Construction Queue -->
    @if(BuildingService.ConstructionQueue.Count > 0)
    {
        <div class="espacial-queue-container mb-lg">
            <h3>Construction Queue</h3>
            @foreach (var item in BuildingService.ConstructionQueue)
            {
                <div class="espacial-queue-item" @key="item">
                    <div>
                        <strong>@item.Title</strong> - Level @(item.Level + 1)
                        <div class="text-muted" style="font-size: 0.9em;">Duration: @item.ConstructionDuration.ToString(@"hh\:mm\:ss")</div>
                    </div>
                    <button class="espacial-btn espacial-btn-danger espacial-btn-sm"
                            @onclick="async () => await BuildingService.CancelAsync(item)">
                        Cancel
                    </button>
                    @if (item.IsBuilding)
                    {
                        <span class="espacial-queue-timer">@item.TimeRemaining.ToString(@"hh\:mm\:ss")</span>
                    }
                </div>
            }
        </div>
    }

    <!-- Buildings Grid -->
    <div class="espacial-grid-4">
        @foreach (var building in BuildingService.Buildings)
        {
            <div class="espacial-card">
                <!-- Level Badge -->
                <div class="espacial-badge">Level @building.Level</div>

                <!-- Building Image -->
                <img src="@SkinConfig.Url(building.Image)" alt="@building.Title" />

                <!-- Building Info -->
                <h3>@building.Title</h3>
                <p class="text-muted">@building.Description</p>

                <!-- Costs -->
                <div class="espacial-cost-section">
                    <div class="espacial-cost-item">
                        <img src="@SkinConfig.Url("common/metal-icon.png")" alt="Metal" />
                        Metal: @building.MetalCost.ToString("N0")
                    </div>
                    <div class="espacial-cost-item">
                        <img src="@SkinConfig.Url("common/crystal-icon.png")" alt="Crystal" />
                        Crystal: @building.CrystalCost.ToString("N0")
                    </div>
                    <div class="espacial-cost-item">
                        <img src="@SkinConfig.Url("common/deuterium-icon.png")" alt="Deuterium" />
                        Deuterium: @building.DeuteriumCost.ToString("N0")
                    </div>
                    <div class="text-muted" style="margin-top: 8px; font-size: 0.85em;">
                        <div>Duration: @BuildingService.GetConstructionTime(building).ToString(@"hh\:mm\:ss")</div>
                        <div>Energy: @building.EnergyConsumption</div>
                    </div>
                </div>

                <!-- Action Buttons -->
                @if (!BuildingService.IsQueued(building.Title))
                {
                    // Convert List<string> to Dictionary for compatibility
                    var requirements = new Dictionary<string, int>();
                    if(building.Dependencies != null)
                    {
                        foreach(var dep in building.Dependencies) requirements.Add(dep, 1);
                    }

                    @if (RequirementService.IsUnlocked(requirements))
                    {
                        @if (building.Level < 1)
                        {
                            <button class="espacial-btn espacial-btn-primary espacial-btn-block"
                                    @onclick="async () => await BuildingService.AddToQueueAsync(building)">
                                Construct
                            </button>
                        }
                        else
                        {
                            <button class="espacial-btn espacial-btn-primary espacial-btn-block"
                                    @onclick="async () => await BuildingService.AddToQueueAsync(building)">
                                Upgrade to Level @(building.Level + 1)
                            </button>
                        }
                    }
                    else
                    {
                        <button class="espacial-btn espacial-btn-block" disabled>
                            Locked
                        </button>
                    }
                }
                else
                {
                    var queuedBuilding = BuildingService.GetQueuedBuilding(building.Title);
                    @if(queuedBuilding != null)
                    {
                        <div class="text-center mb-sm">
                            <div class="espacial-queue-timer">@queuedBuilding.TimeRemaining.ToString(@"hh\:mm\:ss")</div>
                        </div>
                        <button class="espacial-btn espacial-btn-danger espacial-btn-block"
                                @onclick="async () => await BuildingService.CancelAsync(queuedBuilding)">
                            Cancel
                        </button>
                    }
                }
            </div>
        }
    </div>
</div>

@code {
    protected override void OnInitialized()
    {
        ResourceService.OnChange += RefreshState;
        BuildingService.OnChange += RefreshState;
        _ = BuildingService.UpdateProductionAsync();
    }

    private async void RefreshState()
    {
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        ResourceService.OnChange -= RefreshState;
        BuildingService.OnChange -= RefreshState;
    }
}



